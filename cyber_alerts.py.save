import requests
import os
from datetime import datetime

# ==========================================
# CONFIGURACIÓN DE CREDENCIALES
# ==========================================
NEWSAPI_KEY = "TU_NEWSAPI_KEY_AQUI"
TELEGRAM_TOKEN = "TU_TELEGRAM_BOT_TOKEN_AQUI"
TELEGRAM_CHAT_ID = "TU_CHAT_ID_AQUI"

# Empresa a rastrear (puedes usar "CrowdStrike", "Microsoft", etc.)
EMPRESA_OBJETIVO = "CrowdStrike" 
ARCHIVO_HISTORIAL = "enviadas.txt"

def cargar_historial():
    """Lee el archivo de texto y devuelve una lista con los links ya enviados."""
    if not os.path.exists(ARCHIVO_HISTORIAL):
        return []
    with open(ARCHIVO_HISTORIAL, "r", encoding="utf-8") as f:
        # Eliminamos saltos de línea (\n) de cada enlace
        return [line.strip() for line in f.readlines()]

def guardar_en_historial(link):
    """Añade un nuevo link al archivo de texto para no repetirlo."""
    with open(ARCHIVO_HISTORIAL, "a", encoding="utf-8") as f:
        f.write(link + "\n")

def buscar_noticias():
    """Consulta NewsAPI buscando menciones de la empresa."""
    # endpoint 'everything' busca en el contenido y títulos de miles de medios
    url = f"https://newsapi.org/v2/everything?q={EMPRESA_OBJETIVO}&sortBy=publishedAt&apiKey={NEWSAPI_KEY}"
    
    try:
        response = requests.get(url)
        # Convertimos la respuesta string/bytes de la API a un diccionario de Python
        datos = response.json() 
        
        if datos.get("status") == "ok":
            return datos.get("articles", [])
        else:
            print(f"Error de la API: {datos.get('message')}")
            return []
    except Exception as e:
        print(f"Error de conexión con NewsAPI: {e}")
        return []

def enviar_a_telegram(titulo, fuente, link):
    """Envía un formato elegante de alerta a tu chat de Telegram."""
    url_telegram = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    
    # Formateamos el texto con Markdown para que se vea profesional en el móvil
    mensaje = (
        f"🔔 *NUEVA NOTICIA DETECTADA*\n"
        f"📈 *Empresa:* {EMPRESA_OBJETIVO}\n\n"
        f"📝 *Titular:* {titulo}\n"
        f"📰 *Fuente:* {fuente}\n\n"
        f"🔗 [Abrir Noticia]({link})"
    )
    
    payload = {
        "chat_id": TELEGRAM_CHAT_ID,
        "text": mensaje,
        "parse_mode": "Markdown"
    }
    
    try:
        requests.post(url_telegram, json=payload)
    except Exception as e:
        print(f"No se pudo enviar a Telegram: {e}")

def ejecutar_rastreador():
    print(f"[{datetime.now()}] Iniciando escaneo para {EMPRESA_OBJETIVO}...")
    
    noticias = buscar_noticias()
    enviadas = cargar_historial()
    nuevas_noticias_contador = 0

    # Evaluamos las top 5 noticias más recientes que devolvió la API
    for articulo in noticias[:5]:
        link = articulo.get("url")
        titulo = articulo.get("title")
        fuente = articulo.get("source", {}).get("name", "Medio Desconocido")

        # Validamos que el artículo tenga datos esenciales y no haya sido enviado
        if link and link not in enviadas:
            enviar_a_telegram(titulo, fuente, link)
            guardar_en_historial(link)
            nuevas_noticias_contador += 1
            print(f"Notificación enviada: {titulo[:30]}...")

    print(f"Escaneo finalizado. Se enviaron {nuevas_noticias_contador} alertas nuevas.")

if __name__ == "__main__":
    ejecutar_rastreador()
